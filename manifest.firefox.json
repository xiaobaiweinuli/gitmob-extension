{
  "manifest_version": 2,
  "name": "GitMob — GitHub Favorites Sync",
  "version": "1.0.0",
  "description": "Sync your GitHub favorites across devices with GitMob App in real time.",
  "permissions": [
    "storage",
    "https://github.com/*",
    "https://api.github.com/*",
    "https://*/*"
  ],
  "background": { "scripts": ["src/background/index.ts"], "persistent": false },
  "browser_action": {
    "default_popup": "src/popup/index.html",
    "default_icon":  { "16": "icon-16.png", "48": "icon-48.png", "128": "icon-128.png" }
  },
  "content_scripts": [{
    "matches": ["https://github.com/*/*"],
    "js": ["src/content/index.tsx"],
    "run_at": "document_idle"
  }],
  "icons": { "16": "icon-16.png", "48": "icon-48.png", "128": "icon-128.png" },
  "browser_specific_settings": {
    "gecko": { "id": "gitmob@extension", "strict_min_version": "109.0" }
  }
}
